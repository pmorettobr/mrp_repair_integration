<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_repair_order_form_inherit" model="ir.ui.view">
        <field name="name">repair.order.form.inherit.qc</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="arch" type="xml">

            <!-- ✅ 1. company_id invisível para domínio -->
            <xpath expr="//field[@name='product_id']/.." position="inside">
                <field name="company_id" invisible="1"/>
            </xpath>

            <!-- ✅ 2. Smart Button: Ver Ordens de Produção vinculadas -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_productions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-cogs"
                        attrs="{'invisible': [('production_count', '=', 0)]}"
                        help="Ver Ordens de Produção vinculadas a este reparo">
                    <div class="o_stat_info">
                        <field name="production_count" class="o_stat_value"/>
                        <span class="o_stat_text">OPs</span>
                    </div>
                </button>
            </xpath>

            <!-- ✅ 3. Grupo de Ordens de Produção Vinculadas (CORRIGIDO) -->
            <!-- O grupo precisa estar DENTRO de um xpath com posição definida -->
            <xpath expr="//notebook" position="before">
                <group string="Ordens de Produção Vinculadas" 
                       name="production_link_group" 
                       colspan="4"
                       attrs="{'invisible': [('production_count', '=', 0)]}">
                    <field name="production_ids" nolabel="1" colspan="4">
                        <tree create="0" delete="0" edit="0">
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="product_qty"/>
                            <field name="state" widget="badge"
                                   decoration-info="state=='draft'"
                                   decoration-success="state=='done'"
                                   decoration-warning="state=='confirmed'"/>
                            <field name="date_deadline"/>
                        </tree>
                    </field>
                </group>
            </xpath>

        </field>
    </record>
</odoo>
