<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_repair_order_form_inherit" model="ir.ui.view">
        <field name="name">repair.order.form.inherit.qc</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="arch" type="xml">

            <!-- ✅ company_id no mesmo grupo que product_id (para domínio) -->
            <xpath expr="//field[@name='product_id']/.." position="inside">
                <field name="company_id" invisible="1"/>
            </xpath>

            <!-- ✅ Smart Button: Ver Ordens de Produção vinculadas -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_productions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-cogs"
                        attrs="{'invisible': [('production_count', '=', 0)]}"
                        help="Ver Ordens de Produção vinculadas a este reparo">
                    <div class="o_stat_info">
                        <field name="production_count" class="o_stat_value"/>
                        <span class="o_stat_text">OPs</span>
                    </div>
                </button>
            </xpath>

            <!-- ✅ Botões de QC no header (SEMPRE visíveis quando status = pending) -->
            <xpath expr="//header" position="inside">
                <button name="action_approve_quality"
                        type="object"
                        string="Aprovar QC"
                        class="btn-primary"
                        attrs="{'invisible': [('quality_approval_state', '!=', 'pending')]}"/>
                <button name="action_reject_quality"
                        type="object"
                        string="Rejeitar QC"
                        class="btn-danger"
                        attrs="{'invisible': [('quality_approval_state', '!=', 'pending')]}"/>
                
                <!-- ✅ Mostrar status quando já aprovado/rejeitado -->
                <field name="quality_approval_state" 
                       widget="badge" 
                       decoration-success="quality_approval_state == 'approved'"
                       decoration-danger="quality_approval_state == 'rejected'"
                       attrs="{'invisible': [('quality_approval_state', '=', 'pending')]}"
                       readonly="1"/>
            </xpath>

            <!-- ✅ Campos de QC e vínculo com Produção (antes do notebook) -->
            <xpath expr="//notebook" position="before">
                
                <!-- Grupo de Controle de Qualidade -->
                <group string="Controle de Qualidade" name="quality_group" col="4">
                    <field name="quality_approval_state" widget="badge"/>
                    <field name="quality_approved_by"/>
                    <field name="quality_approval_date"/>
                    <field name="quality_notes" placeholder="Observações do QC..." colspan="4"/>
                </group>

                <!-- Grupo de Ordens de Produção Vinculadas -->
                <group string="Ordens de Produção Vinculadas" name="production_link_group" colspan="4">
                    <field name="production_ids" nolabel="1" colspan="4">
                        <tree create="0" delete="0">
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="product_qty"/>
                            <field name="state" widget="badge"
                                   decoration-info="state=='draft'"
                                   decoration-success="state=='done'"
                                   decoration-warning="state=='confirmed'"/>
                            <field name="date_deadline"/>
                        </tree>
                    </field>
                </group>
            </xpath>

        </field>
    </record>
</odoo>
